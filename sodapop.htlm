<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Soda Pop - Unifi Mini Game</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Pretendard:wght@400;500;700;800&display=swap');
        body { font-family: 'Pretendard', sans-serif; -webkit-tap-highlight-color: transparent; }
        /* 게임 화면을 위한 다크 테마 배경 */
        .game-bg { background: radial-gradient(circle at 50% 50%, #1f2937 0%, #111827 100%); }
    </style>
</head>
<body class="bg-gray-900 flex justify-center items-start min-h-screen relative overflow-x-hidden">

    <div class="w-full max-w-[430px] game-bg min-h-screen shadow-2xl relative flex flex-col text-white">
        
        <header class="flex items-center justify-between px-5 py-4 sticky top-0 bg-gray-900/80 backdrop-blur-md z-50 border-b border-gray-800">
            <button onclick="window.location.href='index.html'" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-gray-800 transition active:scale-95">
                <i class="fa-solid fa-chevron-left text-xl"></i>
            </button>
            <h1 class="text-lg font-extrabold tracking-tight">Soda Pop</h1>
            <div class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-gray-800 transition cursor-pointer">
                <i class="fa-solid fa-ellipsis-vertical text-xl"></i>
            </div>
        </header>

        <main class="flex-1 flex flex-col relative">
            
            <div class="absolute top-4 left-1/2 -translate-x-1/2 bg-black/60 backdrop-blur-md px-4 py-1.5 rounded-full text-xs font-bold text-gray-300 flex items-center gap-2 z-10 border border-gray-700">
                <i class="fa-solid fa-stopwatch text-green-400"></i> 미션: 30초 이상 플레이하기
            </div>

            <div class="flex-1 w-full relative flex items-center justify-center overflow-hidden">
                <img src="https://obs-beta.line-apps.com:443/0hTsVGL6YfC1xrPhSICM10CzFrBS0HTxJJEggZJBZ7ATBYXBcLEichWk5sM2QHZipqHggYcw5VHQcNbypLESccUU9fM20aWykLHggPWQVtLBQOXE91HiQPSghFCTZOcjw" 
                     alt="Soda Pop Game Canvas" 
                     class="w-full h-full object-cover opacity-80 animate-pulse" style="animation-duration: 3s;">
                
                <div class="absolute inset-0 flex flex-col items-center justify-center bg-black/40 backdrop-blur-[2px]">
                    <div class="w-20 h-20 bg-blue-500 rounded-full flex items-center justify-center text-3xl shadow-[0_0_30px_rgba(59,130,246,0.5)] cursor-pointer hover:scale-110 transition-transform pl-1">
                        <i class="fa-solid fa-play"></i>
                    </div>
                    <p class="mt-4 font-bold text-blue-100 tracking-widest text-sm">TAP TO START</p>
                </div>
            </div>
        </main>

        <div class="bg-gray-800 rounded-t-[32px] p-6 pb-safe z-40 border-t border-gray-700 shadow-[0_-10px_40px_rgba(0,0,0,0.5)]">
            <div class="flex justify-between items-center mb-5">
                <div>
                    <p class="text-[11px] text-gray-400 font-medium mb-1">데일리 미션 보상</p>
                    <p class="text-xl font-black text-white flex items-center gap-2">
                        +0.03 <span class="text-sm font-bold text-blue-400">USDT</span>
                    </p>
                </div>
                <div class="text-right">
                    <p class="text-[11px] text-gray-400 font-medium mb-1">내 자산</p>
                    <p class="text-sm font-bold text-gray-200">4,791.07 USDT</p>
                </div>
            </div>

            <button id="claimBtn" onclick="claimReward()" class="w-full bg-blue-600 text-white py-4 rounded-[16px] text-[15px] font-extrabold active:bg-blue-700 active:scale-95 transition-all shadow-lg shadow-blue-900 flex justify-center items-center gap-2">
                보상 수령하고 홈으로 가기
            </button>
        </div>
    </div>

    <script>
        function claimReward() {
            const btn = document.getElementById('claimBtn');
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> 수령 중...';
            btn.classList.replace('bg-blue-600', 'bg-blue-800');
            
            // 1초 뒤 알림 띄우고 메인 페이지로 강제 이동
            setTimeout(() => {
                alert('0.03 USDT 보상을 획득했습니다!');
                window.location.href = 'index.html'; 
            }, 1000);
        }
    </script>
</body>
</html>